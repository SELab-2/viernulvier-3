#!/bin/bash
set -u -o pipefail -o noclobber

function print_help() {
cat <<END_HELP
 All our commands gathered together so we don't forget them.
 This gathers them hierarchically, check out each subcommand.

 All subcommands are "mandatory" in the sense that if they are not specified,
 this script will ask for them one by one. So not even required to remember
 the subcommands for this command!

 Subcommands:
   stack             Working with the "real" services/containers
   test              Running tests
   worker            Working with the short-lived scripts/containers

 Each subcommand has its own '--help' command.
END_HELP
}

function print_stack_help() {
cat <<END_HELP
 Interact with the main containers (frontend, backend, database, proxy).

 Subcommands:
   up [build]                   Spin up the containers
   down [remove]                Spin down the containers
   logs [follow] [<service>]    Show the logs for the containers

 The [build], [remove] and [follow] are arguments, where each is a yes/no
 but can also use their name (like 'build' or 'no-build').
 For the logs-service, use one of these:
   all, backend, frontend, database, proxy, sync_worker

 Examples:
  ./devx up build
  ./devx down no-remove
  ./devx logs no backend
END_HELP
}

function print_test_help() {
cat <<END_HELP
 Run tests!

 Subcommands:
   backend [normal|coverage|ci]    Run the backend tests
   frontend                        Run the frontend tests

 The 'backend coverage' will try to open the generated html page with
 'xdg-open'.

 Examples:
   ./devx test backend coverage
   ./devx test backend ci
   ./devx test frontend
END_HELP
}

function print_worker_help() {
cat <<END_HELP
 Run a worker.

 Subcommands:
   sync [build]         Run the sync worker once
   csv [build]          Run the csv worker once

 The [build] is an argument that accepts yes or no, but can also use their name
 (like 'build' or 'no-build').

 Examples:
   ./devx worker sync no-build
   ./devx worker csv yes
END_HELP
}

# Navigate to the root directory
git_root=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z "$git_root" ]]; then
	echo "Not in a git repository, aborting." >&2
	exit 1
fi

cd "$git_root" || exit 1

# Source the necessary files
source ".env"
source "backend/.venv/bin/activate"


# Helper function to select one thing from options
choose_return=""
function choose() {
	local prompt="$1";
	shift
	local options=("$@")

	echo "$prompt"
	PS3="Select a number: "
	select opt in "${options[@]}"; do
		if [[ -n "$opt" ]]; then
			choose_return="$opt"
			break
		else
			echo "Invalid choice, try again."
		fi
	done
}

function run() {
	echo "[CMD] $*"
	eval "$*"
}


# Stack subcommand
function stack() {
	local action="${1:-}"
	if [[ "$action" == --help || "$action" == -h ]]; then
		print_stack_help
		exit 0
	fi

	if [[ -z "$action" ]]; then
		choose "Stack action?" up down logs
		action="$choose_return"
	fi

	case "$action" in
		up)
			local mode="${2:-}"
			if [[ -z "$mode" ]]; then
				choose "Build before starting?" yes no
				mode="$choose_return"
			fi

			if [[ "$mode" == "yes" ]]; then
				run docker compose up --build --wait -d
			else
				run docker compose up -d
			fi
			;;
		down)
			local wipe="${2:-}"
			if [[ -z "$wipe" ]]; then
				choose "Remove volumes?" no yes
				wipe="$choose_return"
			fi

			if [[ "$wipe" == "yes" ]]; then
				run docker compose down -v
			else
				run docker compose down
			fi
			;;
		logs)
			local follow="${2:-}"
			local service="${3:-}"

			case "$follow" in
				follow)
					follow="yes"
					;;
				no-follow)
					follow="no"
					;;
				yes|no)
					;;
				*)
				choose "Follow logs?" yes no
				follow="$choose_return"
			esac

			services=(all backend frontend database proxy sync_worker)
			# If requested service is not in available services, ask
			if [[ " ${services[*]} " =~ [[:space:]]${service}[[:space:]] ]]; then
				choose "Service?" ${services[@]}
				service="$choose_return"
			fi

			cmd="docker compose logs"
			[[ "$follow" == "yes" ]] && cmd="$cmd -f"
			[[ "$service" != "all" ]] && cmd="$cmd $service"

			run "$cmd"
			;;
	esac
}

# Test subcommand
function test_cmd() {
	local target="${1:-}"

	if [[ -z "$target" ]]; then
		choose "Test target?" backend frontend
		target="$choose_return"
	fi

	case "$target" in
		backend)
			local mode="${2:-}"
			if [[ -z "$mode" ]]; then
				choose "Mode?" normal coverage ci
				mode="$choose_return"
			fi

			case "$mode" in
				normal)
					run cd backend && run pytest
					;;
				coverage)
					(
						run cd backend \
							&& run coverage run -m pytest \
							&& run coverage html \
							&& run xdg-open htmlcov/index.html >/dev/null 2>&1
					)
					;;
				ci)
					run docker compose -f docker-compose.ci.yml \
						--project-name viernulvier-ci \
						exec -T backend pytest tests/
					;;
				esac
				;;
			frontend)
				run cd frontend && run npm test
				;;
		esac
}

# Worker subcommand
function worker() {
	local type="${1:-}"

	if [[ -z "$type" ]]; then
		choose "Worker?" sync csv
		type="$choose_return"
	fi

	# TODO: build argument
	case "$type" in
		sync)
			run docker compose --profile sync run --rm sync_worker
			;;
		csv)
			run docker compose --profile csv run --rm csv_worker
			;;
	esac
}

# Main entrypoint
main() {
	local cmd="${1:-}"

	if [[ -z "$cmd" ]]; then
		choose "What do you want to do?" stack test worker
		cmd="$choose_return"
	fi

	case "$cmd" in
		stack) shift; stack "$@" ;;
		test) shift; test_cmd "$@" ;;
		worker) shift; worker "$@" ;;
		--help|-h)
			print_help
			exit 0
			;;
		*)
			echo "Unknown command: $cmd" >&2
			exit 1
			;;
	esac
}

main "$@"
